{
  "name": "tennis-stringing-site",
  "version": "1.0.0",
  "private": true,
  "description": "Tennis Stringing & Racket Services - static site",
  "scripts": {
    "build": "npm run build:css && npm run copy-assets && npm run build:js",
    "build:css": "postcss css/style.css --output css/bundle.css",
    "copy-assets": "node -e \"const fs=require('fs'),p=require('path');const src=p.resolve('../../packages/design-system/assets');const dest=p.resolve('assets');const copyDir=(srcDir,destDir)=>{fs.mkdirSync(destDir,{recursive:true});fs.readdirSync(srcDir).forEach(f=>{const srcPath=p.join(srcDir,f);const destPath=p.join(destDir,f);fs.statSync(srcPath).isDirectory()?copyDir(srcPath,destPath):fs.copyFileSync(srcPath,destPath)})};copyDir(src,dest);console.log('Assets copied')\"",
    "build:js": "esbuild js/main.js --bundle --outfile=js/bundle.js --minify",
    "dev": "npm run build:css && browser-sync start --server --files '.' --watch --no-notify --port 8080",
    "lint": "eslint js/main.js",
    "dev:hard": "node -e \"console.clear(); console.log('Clearing sessionStorage...'); console.log('Starting dev server with hard refresh...')\" && browser-sync start --server --files '.' --watch --no-notify --port 8080 --startPath '/?clear-splash=true'"
  },
  "dependencies": {
    "@vnyson/design-system": "workspace:*",
    "atropos": "^2.0.2",
    "gsap": "^3.15.0"
  },
  "devDependencies": {
    "browser-sync": "^3.0.2",
    "esbuild": "^0.28.0",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.0.1"
  }
}
