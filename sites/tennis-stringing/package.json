{
  "name": "tennis-stringing-site",
  "version": "1.0.0",
  "private": true,
  "description": "Tennis Stringing & Racket Services - static site (legacy) + Astro (refactor in progress)",
  "type": "module",
  "scripts": {
    "dev": "npm run build:css && npm run watch:css & browser-sync start --server --files 'css/bundle.css, js/bundle.js, *.html' --watch --no-notify --port 8080",
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss css/style.css --output css/bundle.css",
    "build:js": "esbuild js/main.js --bundle --outfile=js/bundle.js --minify",
    "watch:css": "postcss css/style.css --output css/bundle.css --watch",
    "lint": "eslint js/main.js",
    "dev:astro": "astro dev --port 8080",
    "build:astro": "astro build",
    "preview:astro": "astro preview",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@vnyson/design-system": "workspace:*",
    "astro": "^6.4.4"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "browser-sync": "^3.0.2",
    "esbuild": "^0.28.0",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.0.1",
    "postcss-url": "^10.1.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.3"
  }
}
