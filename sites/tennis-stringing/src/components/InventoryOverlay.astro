<!-- Inventory Overlay -->
<div id="inventory-overlay" class="inventory-overlay hidden">
  <div
    class="inventory-overlay__content panel-pixel pixel-borders pixel-borders--2 pixel-borders--inset pixel-borders--inset-all"
  >
    <div class="inventory-overlay__header">
      <h2>inventory</h2>
      <button
        class="inventory-overlay__close pixel-borders pixel-borders--1"
        aria-label="Close inventory"
      >
        x
      </button>
    </div>
    <div id="inventory-grid" class="inventory-table-container">
      <p>Loading inventory...</p>
    </div>
  </div>
</div>