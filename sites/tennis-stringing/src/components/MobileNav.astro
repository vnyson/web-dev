<!-- Mobile Navigation Overlay -->
<div
  class="mobile-section mobile-navigation-bottom panel-pixel pixel-borders pixel-borders--2 pixel-borders--inset pixel-borders--inset-all"
>
  <div class="queue-indicator mobile">
    <p class="queue-label mobile">QUEUE</p>
    <img
      class="queue-image"
      src="/assets/images/queue/Pokemon Hospital-0.png"
      alt="Queue status"
      data-gif-src="/assets/images/queue/Pokemon Hospital.gif"
    />
    <p class="queue-text mobile">Loading...</p>
  </div>
  <div class="nav-button-wrapper">
    <button
      class="panel-pixel pixel-borders pixel-borders--2 pixel-borders--inset pixel-borders--inset-all pixel-border-theme--warning button-mobile profile-button-mobile"
      aria-label="View Profile"
    >
      <img src="/assets/images/navigation/profile.png" alt="Profile" />
    </button>
    <span class="nav-button-label">PROF.</span>
  </div>
  <div class="nav-button-wrapper">
    <button
      class="panel-pixel pixel-borders pixel-borders--2 pixel-borders--inset pixel-borders--inset-all pixel-border-theme--success button-mobile inventory-button-mobile"
      aria-label="View inventory"
    >
      <img src="/assets/images/navigation/backpack-inventory.png" alt="Inventory" />
    </button>
    <span class="nav-button-label">INVENT.</span>
  </div>
  <div class="nav-button-wrapper">
    <button
      class="panel-pixel pixel-borders pixel-borders--2 pixel-borders--inset pixel-borders--inset-all pixel-border-theme--danger button-mobile demo-button-mobile"
      aria-label="View demo rackets"
    >
      <img src="/assets/images/navigation/pokedex-demo.png" alt="Demo" />
    </button>
    <span class="nav-button-label">DEMO</span>
  </div>
</div>
