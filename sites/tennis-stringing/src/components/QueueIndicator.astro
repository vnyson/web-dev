---
// Queue status indicator card (Desktop + Mobile variant)
---

<div
  class="panel-pixel pixel-borders pixel-borders--2 pixel-borders--inset pixel-borders--inset-all queue-card"
>
  <div class="queue-indicator">
    <p class="queue-label">QUEUE</p>
    <img
      class="queue-image"
      src="/assets/images/queue/Pokemon Hospital-0.png"
      alt="Queue status"
      data-gif-src="/assets/images/queue/Pokemon Hospital.gif"
    />
    <p class="queue-text">Loading...</p>
  </div>
</div>