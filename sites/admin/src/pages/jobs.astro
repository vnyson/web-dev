---
import '../styles/global.css';
import { fetchStringing, getAuthToken } from '../lib/api';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Jobs - Tennis Admin</title>
	</head>
	<body class="bg-gray-50">
		<div class="min-h-screen">
			<nav class="bg-white shadow-sm">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					<div class="flex justify-between h-16">
						<div class="flex">
							<div class="flex-shrink-0 flex items-center">
								<h1 class="text-xl font-bold text-gray-900">Tennis Admin</h1>
							</div>
							<div class="hidden sm:ml-6 sm:flex sm:space-x-8">
								<a href="/" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Dashboard</a>
								<a href="/inventory" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Inventory</a>
								<a href="/jobs" class="border-indigo-500 text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Jobs</a>
								<a href="/players" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Players</a>
							</div>
						</div>
						<div class="flex items-center sm:hidden">
							<button type="button" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')" aria-controls="mobile-menu" aria-expanded="false" class="inline-flex items-center justify-center p-2 rounded-md text-gray-500 hover:text-gray-700 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500">
								<span class="sr-only">Toggle navigation menu</span>
								<svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
								</svg>
							</button>
						</div>
						<div id="mobile-menu" class="hidden sm:hidden">
							<div class="px-4 pb-3 space-y-1">
								<a href="/" class="block rounded-md px-3 py-2 text-base font-medium text-gray-700 bg-gray-50 hover:bg-gray-100">Dashboard</a>
								<a href="/inventory" class="block rounded-md px-3 py-2 text-base font-medium text-gray-700 bg-gray-50 hover:bg-gray-100">Inventory</a>
								<a href="/jobs" class="block rounded-md px-3 py-2 text-base font-medium text-gray-700 bg-gray-50 hover:bg-gray-100">Jobs</a>
								<a href="/players" class="block rounded-md px-3 py-2 text-base font-medium text-gray-700 bg-gray-50 hover:bg-gray-100">Players</a>
							</div>
						</div>
						<div class="flex items-center">
							<a href="/login" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
								Login with Google
							</a>
						</div>
					</div>
				</div>
			</nav>

			<main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
				<div class="px-4 py-6 sm:px-0">
					<div class="flex justify-between items-center mb-6">
						<h2 class="text-2xl font-bold text-gray-900">Stringing Jobs</h2>
						<a href="/jobs/new" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
							New Drop Off
						</a>
					</div>

					<div class="bg-white shadow rounded-lg mb-6">
						<div class="overflow-x-auto">
							<table class="min-w-full divide-y divide-gray-200">
								<thead class="bg-gray-50">
									<tr>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Player</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Racket</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">String</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tension</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
										<th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
									</tr>
								</thead>
								<tbody class="bg-white divide-y divide-gray-200" id="jobs-table">
									<tr>
										<td colspan="8" class="px-6 py-4 text-center text-sm text-gray-500">
											Loading jobs...
										</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>

					<h3 class="text-xl font-bold text-gray-900 mb-4">Completed Jobs</h3>
					<div class="bg-white shadow rounded-lg">
						<div class="overflow-x-auto">
							<table class="min-w-full divide-y divide-gray-200">
								<thead class="bg-gray-50">
									<tr>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Player</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Racket</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">String</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tension</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
										<th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
									</tr>
								</thead>
								<tbody class="bg-white divide-y divide-gray-200" id="done-jobs-table">
									<tr>
										<td colspan="8" class="px-6 py-4 text-center text-sm text-gray-500">
											Loading completed jobs...
										</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</main>
		</div>

		<script>
			import { getAuthToken, fetchStringing, createStringingJob, updateStringingJob, API_URL, getAuthHeaders } from '../lib/api';

			// Check authentication on page load
			if (!getAuthToken()) {
				window.location.href = '/login';
			}

			async function loadJobs() {
				try {
					const jobs = await fetchStringing();
					
					// Separate active and done jobs
					const activeJobs = jobs.filter(job => job.status !== 'done');
					const doneJobs = jobs.filter(job => job.status === 'done');
					
					// Sort active jobs by importance: rush first, then by status (queued, ready_for_pickup), then by created_at
					const sortedActiveJobs = activeJobs.sort((a, b) => {
						// Rush jobs first
						if (a.priority === 'rush' && b.priority !== 'rush') return -1;
						if (a.priority !== 'rush' && b.priority === 'rush') return 1;
						
						// Then by status: queued, ready_for_pickup
						const statusOrder = { 'queued': 0, 'ready_for_pickup': 1 };
						const aStatusOrder = statusOrder[a.status] ?? 2;
						const bStatusOrder = statusOrder[b.status] ?? 2;
						if (aStatusOrder !== bStatusOrder) return aStatusOrder - bStatusOrder;
						
						// Then by created_at (newest first)
						return new Date(b.created_at) - new Date(a.created_at);
					});
					
					// Sort done jobs by created_at (newest first)
					const sortedDoneJobs = doneJobs.sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
					
					const tbody = document.getElementById('jobs-table');
					const doneTbody = document.getElementById('done-jobs-table');
					
					// Populate active jobs table
					if (sortedActiveJobs.length === 0) {
						tbody.innerHTML = `
							<tr>
								<td colspan="8" class="px-6 py-4 text-center text-sm text-gray-500">
									No active jobs.
								</td>
							</tr>
						`;
					} else {
						tbody.innerHTML = sortedActiveJobs.map(job => {
							const isRush = job.priority === 'rush';
							const statusClass = job.status === 'queued' ? 'bg-yellow-100 text-yellow-800' :
												job.status === 'ready_for_pickup' ? 'bg-green-100 text-green-800' :
												'bg-gray-100 text-gray-800';
							
							return `
							<tr class="${isRush ? 'bg-red-50' : ''}">
								<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
									${job.player_name || job.player_id}
									${isRush ? '<span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">RUSH</span>' : ''}
								</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${job.job_type || 'stringing'}</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${job.racquet || '-'}</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${job.string_mains || job.string || '-'}</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${job.tension_mains || job.tension || '-'}${job.tension_unit || ''}</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm">
									<span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full ${statusClass}">
										${job.status || 'queued'}
									</span>
								</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${new Date(job.created_at).toLocaleDateString()}</td>
								<td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
									<button class="text-indigo-600 hover:text-indigo-900 mr-2" data-id="${job.id}" data-action="progress">Progress</button>
									<button class="text-indigo-600 hover:text-indigo-900 mr-2" data-id="${job.id}" data-action="edit">Edit</button>
									<button class="text-red-600 hover:text-red-900" data-id="${job.id}" data-action="delete">Delete</button>
								</td>
							</tr>
						`;
						}).join('');
					}
					
					// Populate done jobs table
					if (sortedDoneJobs.length === 0) {
						doneTbody.innerHTML = `
							<tr>
								<td colspan="8" class="px-6 py-4 text-center text-sm text-gray-500">
									No completed jobs.
								</td>
							</tr>
						`;
					} else {
						doneTbody.innerHTML = sortedDoneJobs.map(job => {
							const isRush = job.priority === 'rush';
							const statusClass = 'bg-blue-100 text-blue-800';
							
							return `
							<tr class="${isRush ? 'bg-red-50' : ''}">
								<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
									${job.player_name || job.player_id}
									${isRush ? '<span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">RUSH</span>' : ''}
								</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${job.job_type || 'stringing'}</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${job.racquet || '-'}</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${job.string_mains || job.string || '-'}</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${job.tension_mains || job.tension || '-'}${job.tension_unit || ''}</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm">
									<span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full ${statusClass}">
										done
									</span>
								</td>
								<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${new Date(job.created_at).toLocaleDateString()}</td>
								<td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
									<button class="text-indigo-600 hover:text-indigo-900 mr-2" data-id="${job.id}" data-action="edit">Edit</button>
									<button class="text-red-600 hover:text-red-900" data-id="${job.id}" data-action="delete">Delete</button>
								</td>
							</tr>
						`;
						}).join('');
					}
				} catch (error) {
					console.error('Failed to load jobs:', error);
					const tbody = document.getElementById('jobs-table');
					tbody.innerHTML = `
						<tr>
							<td colspan="8" class="px-6 py-4 text-center text-sm text-red-500">
								Failed to load jobs. Please try again later.
							</td>
						</tr>
					`;
				}
			}

			// Add event listeners for job actions
			document.addEventListener('click', async (e) => {
				const button = e.target.closest('button[data-action]');
				if (!button) return;

				const action = button.dataset.action;
				const jobId = button.dataset.id;

				if (action === 'progress') {
					await progressJob(jobId);
				} else if (action === 'edit') {
					await editJob(jobId);
				} else if (action === 'delete') {
					if (confirm('Are you sure you want to delete this job?')) {
						await deleteJob(jobId);
					}
				}
			});

			async function progressJob(jobId) {
				try {
					const jobs = await fetchStringing();
					const job = jobs.find(j => j.id === jobId);
					if (!job) return;

					let newStatus;
					if (job.status === 'queued') {
						newStatus = 'ready_for_pickup';
					} else if (job.status === 'ready_for_pickup') {
						newStatus = 'done';
					} else {
						return; // Already done, can't progress further
					}

					await updateStringingJob(jobId, { status: newStatus });
					loadJobs();
				} catch (error) {
					console.error('Error progressing job:', error);
					alert('Failed to progress job. Please try again.');
				}
			}

			async function editJob(jobId) {
				// Redirect to edit page (to be implemented)
				window.location.href = `/jobs/edit/${jobId}`;
			}

			async function deleteJob(jobId) {
				try {
					const response = await fetch(`${API_URL}/api/stringing/${jobId}`, {
						method: 'DELETE',
						headers: getAuthHeaders(),
					});
					if (!response.ok) throw new Error('Failed to delete job');
					loadJobs();
				} catch (error) {
					console.error('Error deleting job:', error);
					alert('Failed to delete job. Please try again.');
				}
			}

			// Load jobs when page loads
			loadJobs();
		</script>
	</body>
</html>

