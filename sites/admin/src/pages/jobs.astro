---
import '../styles/global.css';
import { fetchStringing } from '../lib/api';

let stringing = [];

try {
  stringing = await fetchStringing();
} catch (e) {
  console.error('Failed to fetch stringing jobs:', e);
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Jobs - Tennis Admin</title>
	</head>
	<body class="bg-gray-50">
		<div class="min-h-screen">
			<nav class="bg-white shadow-sm">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					<div class="flex justify-between h-16">
						<div class="flex">
							<div class="flex-shrink-0 flex items-center">
								<h1 class="text-xl font-bold text-gray-900">Tennis Admin</h1>
							</div>
							<div class="hidden sm:ml-6 sm:flex sm:space-x-8">
								<a href="/" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Dashboard</a>
								<a href="/inventory" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Inventory</a>
								<a href="/jobs" class="border-indigo-500 text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Jobs</a>
								<a href="/players" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Players</a>
							</div>
						</div>
					</div>
				</div>
			</nav>

			<main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
				<div class="px-4 py-6 sm:px-0">
					<div class="flex justify-between items-center mb-6">
						<h2 class="text-2xl font-bold text-gray-900">Stringing Jobs</h2>
						<a href="/jobs/new" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
							New Drop Off
						</a>
					</div>

					<div class="bg-white shadow rounded-lg">
						<div class="overflow-x-auto">
							<table class="min-w-full divide-y divide-gray-200">
								<thead class="bg-gray-50">
									<tr>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Player</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Racquet</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">String</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tension</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
										<th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
									</tr>
								</thead>
								<tbody class="bg-white divide-y divide-gray-200">
									{stringing.length === 0 ? (
										<tr>
											<td colspan="7" class="px-6 py-4 text-center text-sm text-gray-500">
												No stringing jobs yet. Create your first drop-off to get started.
											</td>
										</tr>
									) : (
										stringing.map((job: any) => (
											<tr>
												<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{job.player_id}</td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{job.racquet}</td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{job.string_mains || job.string}</td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{job.tension_mains || job.tension}{job.tension_unit || ''}</td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{job.status}</td>
												<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{new Date(job.created_at).toLocaleDateString()}</td>
												<td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
													<button class="text-indigo-600 hover:text-indigo-900 mr-3">Edit</button>
													<button class="text-red-600 hover:text-red-900">Delete</button>
												</td>
											</tr>
										))
									)}
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</main>
		</div>
	</body>
</html>
