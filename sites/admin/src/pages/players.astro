			async function generateShareableLink(playerId) {
				try {
					const data = await regeneratePlayerToken(playerId);

					const container = document.querySelector(`.shareable-link-container[data-player-id="${playerId}"]`);
					const input = document.querySelector(`.shareable-link-input[data-player-id="${playerId}"]`);
					if (container && input) {
						input.value = data.shareableLink;
						container.classList.remove('hidden');
					}
				} catch (error) {
					console.error('Failed to generate shareable link:', error);
					alert('Failed to generate shareable link. Please try again.');
				}
			}

			// ---- Fuzzy search for players table ----
			let cachedPlayers: any[] = [];
			const playerFuzzyInput = document.getElementById('player-fuzzy-search') as HTMLInputElement;

			function filterPlayersTable() {
				const query = (playerFuzzyInput?.value || '').trim();
				const tbody = document.getElementById('players-table');
				if (!tbody) return;

				if (!query) {
					tbody.querySelectorAll('.player-row').forEach((row) => { (row as HTMLElement).style.display = ''; });
					tbody.querySelectorAll('.player-details').forEach((row) => { (row as HTMLElement).style.display = ''; });
					return;
				}

				cachedPlayers.forEach((player: any) => {
					const searchable = [player.name, player.club, player.phone, player.level, player.style, player.email].filter(Boolean).join(' ');
					const score = fuzzyScore(query, searchable);
					const row = tbody.querySelector(`tr.player-row[data-id="${player.id}"]`);
					const details = tbody.querySelector(`tr.player-details[data-player-id="${player.id}"]`);
					if (row) (row as HTMLElement).style.display = score > 0 ? '' : 'none';
					if (details) (details as HTMLElement).style.display = 'none';
				});
			}

			if (playerFuzzyInput) {
				playerFuzzyInput.addEventListener('input', filterPlayersTable);
			}

			// Load players when page loads
			loadPlayers();
		</script>
	</body>
</html>