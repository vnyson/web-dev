								const playerId = btn.dataset.playerId;
								const isCurrentlyAvailable = btn.dataset.available === '1';
								try {
									await updateRacket(racketId, { available_for_sale: isCurrentlyAvailable ? 0 : 1 });
									loadRackets(playerId);
