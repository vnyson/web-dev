---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Players - Tennis Admin</title>
	</head>
	<body class="bg-gray-50">
		<div class="min-h-screen">
			<nav class="bg-white shadow-sm">
				<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
					<div class="flex justify-between h-16">
						<div class="flex">
							<div class="flex-shrink-0 flex items-center">
								<h1 class="text-xl font-bold text-gray-900">Tennis Admin</h1>
							</div>
							<div class="hidden sm:ml-6 sm:flex sm:space-x-8">
								<a href="/" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Dashboard</a>
								<a href="/inventory" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Inventory</a>
								<a href="/jobs" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Jobs</a>
								<a href="/players" class="border-indigo-500 text-gray-900 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Players</a>
								<a href="/customization" class="border-transparent text-gray-500 hover:border-gray-300 hover:text-gray-700 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium">Customization</a>
							</div>
						</div>
						<div class="flex items-center sm:hidden">
							<button type="button" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')" aria-controls="mobile-menu" aria-expanded="false" class="inline-flex items-center justify-center p-2 rounded-md text-gray-500 hover:text-gray-700 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500">
								<span class="sr-only">Toggle navigation menu</span>
								<svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
								</svg>
							</button>
						</div>
						<div id="mobile-menu" class="hidden sm:hidden">
							<div class="px-4 pb-3 space-y-1">
								<a href="/" class="block rounded-md px-3 py-2 text-base font-medium text-gray-700 bg-gray-50 hover:bg-gray-100">Dashboard</a>
								<a href="/inventory" class="block rounded-md px-3 py-2 text-base font-medium text-gray-700 bg-gray-50 hover:bg-gray-100">Inventory</a>
								<a href="/jobs" class="block rounded-md px-3 py-2 text-base font-medium text-gray-700 bg-gray-50 hover:bg-gray-100">Jobs</a>
								<a href="/players" class="block rounded-md px-3 py-2 text-base font-medium text-gray-700 bg-gray-50 hover:bg-gray-100">Players</a>
								<a href="/customization" class="block rounded-md px-3 py-2 text-base font-medium text-gray-700 bg-gray-50 hover:bg-gray-100">Customization</a>
							</div>
						</div>
						<div class="flex items-center">
							<a href="/login" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
								Login with Google
							</a>
						</div>
					</div>
				</div>
			</nav>

			<main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
				<div class="px-4 py-6 sm:px-0">
				<div class="flex justify-between items-center mb-6">
					<h2 class="text-2xl font-bold text-gray-900">Players</h2>
					<button id="add-player-btn" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
						Add Player
					</button>
				</div>
				<div class="mb-4">
					<label for="player-fuzzy-search" class="sr-only">Search players</label>
					<input type="text" id="player-fuzzy-search" placeholder="Search players by name, club, or phone..." autocomplete="off" class="block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
				</div>

					<!-- Add/Edit Player Modal -->
					<div id="player-modal" class="fixed inset-0 bg-gray-500 bg-opacity-75 hidden items-center justify-center z-50">
						<div class="bg-white rounded-lg shadow-xl max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
							<div class="px-6 py-4 border-b border-gray-200">
								<h3 id="modal-title" class="text-lg font-medium text-gray-900">Add Player</h3>
							</div>
							<form id="player-form" class="px-6 py-4 space-y-4">
								<input type="hidden" id="player-id" name="id" />
								<div class="grid grid-cols-1 gap-y-4 gap-x-4 sm:grid-cols-2">
									<div class="sm:col-span-2">
										<label for="name" class="block text-sm font-medium text-gray-700">Name *</label>
										<input type="text" name="name" id="name" required class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div>
										<label for="email" class="block text-sm font-medium text-gray-700">Email</label>
										<input type="email" name="email" id="email" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div>
										<label for="phone" class="block text-sm font-medium text-gray-700">Phone</label>
										<input type="text" name="phone" id="phone" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div>
										<label for="club" class="block text-sm font-medium text-gray-700">Club</label>
										<input type="text" name="club" id="club" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div>
										<label for="level" class="block text-sm font-medium text-gray-700">Level</label>
										<input type="text" name="level" id="level" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div>
										<label for="style" class="block text-sm font-medium text-gray-700">Style</label>
										<input type="text" name="style" id="style" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div>
										<label for="grip" class="block text-sm font-medium text-gray-700">Grip</label>
										<input type="text" name="grip" id="grip" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div>
										<label for="string_pref" class="block text-sm font-medium text-gray-700">String Preference</label>
										<input type="text" name="string_pref" id="string_pref" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div>
										<label for="tension" class="block text-sm font-medium text-gray-700">Tension (Mains)</label>
										<input type="text" name="tension" id="tension" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 54" />
									</div>
									<div>
										<label for="tension_cross" class="block text-sm font-medium text-gray-700">Tension (Cross)</label>
										<input type="text" name="tension_cross" id="tension_cross" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 52" />
									</div>
									<div>
										<label for="restring_interval_weeks" class="block text-sm font-medium text-gray-700">Restring Interval (weeks)</label>
										<input type="number" name="restring_interval_weeks" id="restring_interval_weeks" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div class="sm:col-span-2">
										<label for="notes" class="block text-sm font-medium text-gray-700">Notes</label>
										<textarea name="notes" id="notes" rows="3" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"></textarea>
									</div>
									<div class="sm:col-span-2">
										<label for="inventory_preferences" class="block text-sm font-medium text-gray-700">Inventory Preferences</label>
										<textarea name="inventory_preferences" id="inventory_preferences" rows="2" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="Preferred strings, grips, overgrips, etc."></textarea>
									</div>
								</div>
								<div class="flex justify-end space-x-3 mt-6">
									<button type="button" id="cancel-btn" class="inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
										Cancel
									</button>
									<button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
										Save
									</button>
								</div>
							</form>
						</div>
					</div>

					<!-- Add/Edit Racket Modal -->
					<div id="racket-modal" class="fixed inset-0 bg-gray-500 bg-opacity-75 hidden items-center justify-center z-50">
						<div class="bg-white rounded-lg shadow-xl max-w-lg w-full mx-4 max-h-[90vh] overflow-y-auto">
							<div class="px-6 py-4 border-b border-gray-200">
								<h3 id="racket-modal-title" class="text-lg font-medium text-gray-900">Add Racket</h3>
							</div>
							<form id="racket-form" class="px-6 py-4 space-y-4">
								<input type="hidden" id="racket-id" name="id" />
								<input type="hidden" id="racket-player-id" name="player_id" />
								<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
									<div>
										<label for="racket-brand" class="block text-sm font-medium text-gray-700">Brand *</label>
										<input type="text" name="brand" id="racket-brand" required class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div>
										<label for="racket-model" class="block text-sm font-medium text-gray-700">Model</label>
										<input type="text" name="model" id="racket-model" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div>
										<label for="racket-year" class="block text-sm font-medium text-gray-700">Year</label>
										<input type="number" name="year" id="racket-year" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div>
										<label for="racket-head-size" class="block text-sm font-medium text-gray-700">Head Size (sq in)</label>
										<input type="text" name="head_size" id="racket-head-size" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 98" />
									</div>
									<div>
										<label for="racket-length" class="block text-sm font-medium text-gray-700">Length (in)</label>
										<input type="text" name="length" id="racket-length" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 27" />
									</div>
									<div>
										<label for="racket-static-weight" class="block text-sm font-medium text-gray-700">Static Weight (g)</label>
										<input type="text" name="static_weight" id="racket-static-weight" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 320" />
									</div>
									<div>
										<label for="racket-swing-weight" class="block text-sm font-medium text-gray-700">Swing Weight (RA)</label>
										<input type="text" name="swing_weight" id="racket-swing-weight" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 327" />
									</div>
									<div>
										<label for="racket-balance" class="block text-sm font-medium text-gray-700">Balance (cm)</label>
										<input type="text" name="balance" id="racket-balance" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 31.5" />
									</div>
									<div>
										<label for="racket-stiffness" class="block text-sm font-medium text-gray-700">Stiffness (RA)</label>
										<input type="text" name="stiffness" id="racket-stiffness" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 72" />
									</div>
									<div>
										<label for="racket-string-pattern" class="block text-sm font-medium text-gray-700">String Pattern</label>
										<input type="text" name="string_pattern" id="racket-string-pattern" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 16x19" />
									</div>
									<div>
										<label for="racket-beam-width" class="block text-sm font-medium text-gray-700">Beam Width (mm)</label>
										<input type="text" name="beam_width" id="racket-beam-width" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 21" />
									</div>
									<div>
										<label for="racket-grip-size" class="block text-sm font-medium text-gray-700">Grip Size (in)</label>
										<input type="text" name="grip_size" id="racket-grip-size" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" placeholder="e.g., 4.25" />
									</div>
									<div>
										<label for="racket-color" class="block text-sm font-medium text-gray-700">Color</label>
										<input type="text" name="color" id="racket-color" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div class="sm:col-span-2">
										<label for="racket-image-url" class="block text-sm font-medium text-gray-700">Image URL</label>
										<input type="text" name="image_url" id="racket-image-url" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" />
									</div>
									<div class="sm:col-span-2">
										<label for="racket-notes" class="block text-sm font-medium text-gray-700">Notes</label>
										<textarea name="notes" id="racket-notes" rows="2" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm"></textarea>
									</div>
									<div id="racket-owner-field" class="hidden sm:col-span-2">
										<label for="racket-owner" class="block text-sm font-medium text-gray-700">Owner</label>
										<select id="racket-owner" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
											<option value="">Select player...</option>
										</select>
									</div>
								</div>
								<div class="flex justify-end space-x-3 mt-6">
									<button type="button" id="racket-cancel-btn" class="inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
										Cancel
									</button>
									<button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
										Save
									</button>
								</div>
							</form>
						</div>
					</div>

					<div class="bg-white shadow rounded-lg">
						<div class="overflow-x-auto">
							<table class="min-w-full divide-y divide-gray-200">
								<thead class="bg-gray-50">
									<tr>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Club</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Level</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Style</th>
										<th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Phone</th>
										<th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
									</tr>
								</thead>
								<tbody class="bg-white divide-y divide-gray-200" id="players-table">
									<tr>
										<td colspan="6" class="px-6 py-4 text-center text-sm text-gray-500">
											Loading players...
										</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</main>
		</div>

		<script>
			import { getAuthToken, fetchPlayers, createPlayer, fetchRackets, createRacket, updateRacket, deleteRacket as deleteRacketApi, regeneratePlayerToken } from '../lib/api';
			import { fuzzyScore } from '../lib/search';

			// Check authentication on page load
			const token = getAuthToken();
			if (!token) {
				window.location.href = '/login';
			}

			const API_URL = (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1')
				? 'http://127.0.0.1:8787'
				: 'https://tennis-admin-api.vnyson.workers.dev';

			// Player modal elements
			const playerModal = document.getElementById('player-modal');
			const addPlayerBtn = document.getElementById('add-player-btn');
			const cancelBtn = document.getElementById('cancel-btn');
			const playerForm = document.getElementById('player-form');
			const modalTitle = document.getElementById('modal-title');
			const playerIdInput = document.getElementById('player-id');

			// Racket modal elements
			const racketModal = document.getElementById('racket-modal');
			const racketCancelBtn = document.getElementById('racket-cancel-btn');
			const racketForm = document.getElementById('racket-form');
			const racketModalTitle = document.getElementById('racket-modal-title');
			const racketIdInput = document.getElementById('racket-id');
			const racketPlayerIdInput = document.getElementById('racket-player-id');
			const racketBrandInput = document.getElementById('racket-brand');
			const racketModelInput = document.getElementById('racket-model');
			const racketYearInput = document.getElementById('racket-year');
			const racketHeadSizeInput = document.getElementById('racket-head-size');
			const racketLengthInput = document.getElementById('racket-length');
			const racketStaticWeightInput = document.getElementById('racket-static-weight');
			const racketSwingWeightInput = document.getElementById('racket-swing-weight');
			const racketBalanceInput = document.getElementById('racket-balance');
			const racketStiffnessInput = document.getElementById('racket-stiffness');
			const racketStringPatternInput = document.getElementById('racket-string-pattern');
			const racketBeamWidthInput = document.getElementById('racket-beam-width');
			const racketGripSizeInput = document.getElementById('racket-grip-size');
			const racketColorInput = document.getElementById('racket-color');
			const racketImageUrlInput = document.getElementById('racket-image-url');
			const racketNotesInput = document.getElementById('racket-notes');
			const racketOwnerField = document.getElementById('racket-owner-field');
			const racketOwnerSelect = document.getElementById('racket-owner');

			// Cancel button for player modal
			cancelBtn.addEventListener('click', () => {
				playerModal.classList.add('hidden');
				playerModal.classList.remove('flex');
				playerForm.reset();
				playerIdInput.value = '';
				modalTitle.textContent = 'Add Player';
			});

			// Close player modal on backdrop click
			playerModal.addEventListener('click', (e) => {
				if (e.target === playerModal) {
					playerModal.classList.add('hidden');
					playerModal.classList.remove('flex');
					playerForm.reset();
					playerIdInput.value = '';
					modalTitle.textContent = 'Add Player';
				}
			});

			// Handle player form submission
			playerForm.addEventListener('submit', async (e) => {
				e.preventDefault();

				const formData = new FormData(playerForm);
				const data = Object.fromEntries(formData.entries());
				const playerId = playerIdInput.value;

				try {
					if (playerId) {
						// Update existing player
						const response = await fetch(`${API_URL}/api/players/${playerId}`, {
							method: 'PUT',
							headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getAuthToken()}` },
							body: JSON.stringify(data),
						});
						if (!response.ok) throw new Error('Failed to save player');
					} else {
						// Create new player
						await createPlayer(data);
					}

					// Close modal and reload players
					playerModal.classList.add('hidden');
					playerModal.classList.remove('flex');
					loadPlayers();
				} catch (error) {
					console.error('Failed to save player:', error);
					alert('Failed to save player. Please try again.');
				}
			});

			// ---- Racket modal handlers ----

			// Close racket modal
			racketCancelBtn.addEventListener('click', () => {
				closeRacketModal();
			});

			// Close racket modal on backdrop click
			racketModal.addEventListener('click', (e) => {
				if (e.target === racketModal) {
					closeRacketModal();
				}
			});

			// Handle racket form submission
			racketForm.addEventListener('submit', async (e) => {
				e.preventDefault();

				const brand = racketBrandInput.value.trim();
				if (!brand) {
					alert('Brand is required.');
					return;
				}

				const racketId = racketIdInput.value;
				const playerId = racketPlayerIdInput.value;
				const data = {
					brand,
					model: racketModelInput.value.trim() || null,
					year: racketYearInput.value ? parseInt(racketYearInput.value, 10) : null,
					head_size: racketHeadSizeInput.value.trim() || null,
					length: racketLengthInput.value.trim() || null,
					static_weight: racketStaticWeightInput.value.trim() || null,
					swing_weight: racketSwingWeightInput.value.trim() || null,
					balance: racketBalanceInput.value.trim() || null,
					stiffness: racketStiffnessInput.value.trim() || null,
					string_pattern: racketStringPatternInput.value.trim() || null,
					beam_width: racketBeamWidthInput.value.trim() || null,
					grip_size: racketGripSizeInput.value.trim() || null,
					color: racketColorInput.value.trim() || null,
					image_url: racketImageUrlInput.value.trim() || null,
					notes: racketNotesInput.value.trim() || null,
					player_id: racketOwnerField.classList.contains('hidden') ? playerId : racketOwnerSelect.value || playerId,
				};

				try {
					if (racketId) {
						await updateRacket(racketId, data);
					} else {
						await createRacket(data);
					}
					closeRacketModal();
					loadPlayers();
				} catch (error) {
					console.error('Failed to save racket:', error);
					alert('Failed to save racket. Please try again.');
				}
			});

			function closeRacketModal() {
				racketModal.classList.add('hidden');
				racketModal.classList.remove('flex');
				racketForm.reset();
				racketIdInput.value = '';
				racketPlayerIdInput.value = '';
				racketOwnerField.classList.add('hidden');
				racketOwnerSelect.innerHTML = '<option value="">Select player...</option>';
			}

			function openRacketModal(playerId, racketData) {
				racketPlayerIdInput.value = playerId;

				if (racketData) {
					// Edit mode
					racketModalTitle.textContent = 'Edit Racket';
					racketIdInput.value = racketData.id;
					racketBrandInput.value = racketData.brand || '';
					racketModelInput.value = racketData.model || '';
					racketYearInput.value = racketData.year || '';
					racketHeadSizeInput.value = racketData.head_size || '';
					racketLengthInput.value = racketData.length || '';
					racketStaticWeightInput.value = racketData.static_weight || '';
					racketSwingWeightInput.value = racketData.swing_weight || '';
					racketBalanceInput.value = racketData.balance || '';
					racketStiffnessInput.value = racketData.stiffness || '';
					racketStringPatternInput.value = racketData.string_pattern || '';
					racketBeamWidthInput.value = racketData.beam_width || '';
					racketGripSizeInput.value = racketData.grip_size || '';
					racketColorInput.value = racketData.color || '';
					racketImageUrlInput.value = racketData.image_url || '';
					racketNotesInput.value = racketData.notes || '';
					if (racketData.player_id) {
						racketOwnerField.classList.remove('hidden');
						populateOwnerDropdown(playerId, racketData.player_id);
					} else {
						racketOwnerField.classList.add('hidden');
					}
				} else {
					racketModalTitle.textContent = 'Add Racket';
					racketForm.reset();
					racketIdInput.value = '';
					racketOwnerField.classList.add('hidden');
				}

				racketModal.classList.remove('hidden');
				racketModal.classList.add('flex');
				populateOwnerDropdown(playerId, racketData?.player_id);
			}

			async function populateOwnerDropdown(currentPlayerId, selectedPlayerId) {
				try {
					const players = await fetchPlayers();
					racketOwnerSelect.innerHTML = '<option value="">Select player...</option>';
					players.forEach(p => {
						const option = document.createElement('option');
						option.value = p.id;
						option.textContent = p.name;
						if (p.id === selectedPlayerId) {
							option.selected = true;
						}
						racketOwnerSelect.appendChild(option);
					});
				} catch (error) {
					console.error('Failed to load players for owner dropdown:', error);
				}
			}

