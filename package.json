{
  "name": "personal-brand-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Personal brand monorepo with shared design system and multiple sites",
  "workspaces": [
    "packages/*",
    "sites/*"
  ],
  "packageManager": "yarn@4.5.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint 'sites/*/js/**/*.js' && stylelint 'packages/**/*.css' 'sites/**/*.css' && htmlhint 'sites/**/*.html'",
    "lint:css": "stylelint 'packages/**/*.css' 'sites/**/*.css'",
    "lint:html": "htmlhint 'sites/**/*.html'",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "globals": "^15.13.0",
    "htmlhint": "^1.1.4",
    "prettier": "^3.4.2",
    "stylelint": "^16.11.0",
    "stylelint-standard": "^1.1.2",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
