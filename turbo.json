{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "css/bundle.css", "js/bundle.js"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:css": {},
    "lint:html": {},
    "format": {},
    "format:check": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "test:ui": {
      "dependsOn": ["^build"],
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
